  <body>
    <header class="site-header">
      <a class="brand" href="/">
        <span class="brand-mark" aria-hidden="true">TBM</span>
        <span>Take Back the Mac</span>
      </a>
      <nav aria-label="Primary">
        <a href="/manifesto/">Manifesto</a>
        <a href="/#rights">Requests</a>
        <a href="/#idea-form">Add a request</a>
      </nav>
    </header>

    <main>
      <article class="manifesto-article">
        <header class="article-header">
          <p class="tagline">For testers</p>
          <h1>Help test Take Back the Mac.</h1>
          <p class="lede">
            Please read the argument, try the request board, and tell us what
            feels unclear, missing, broken, too sharp, or not sharp enough.
          </p>
        </header>

        <section>
          <h2>What to try</h2>
          <p>
            Read the manifesto, upvote requests that feel important, add a
            request if something is missing, and add comments where you have
            useful examples, evidence, or better wording.
          </p>
          <p>
            New requests and comments are reviewed before they appear publicly.
            Email is optional and only used if follow-up would be helpful.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="/">Start testing</a>
            <a class="button secondary" href="/privacy/">Privacy</a>
          </div>
        </section>
      </article>
    </main>

